# ──────────────────────────────────────────────────────────────
# KalshiBTCPredictionModel15 – Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Kalshi API credentials
# Generate at https://kalshi.com → Account & Security → API Keys
# For demo: generate at https://demo.kalshi.co
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=path/to/your/kalshi-private-key.key

# Mode: "demo" (paper trading) or "live" (real money)
KALSHI_MODE=demo

# Optional: Discord webhook for trade alerts
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
